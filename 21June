class Solution {
    public ListNode reverseList(ListNode head) {
    ListNode temp=head;
    ListNode prev=null;
    while(temp!=null){
        ListNode front=temp.next;  // storing next element so we dont lose it
        temp.next=prev;   
        prev=temp;
        temp=front;
        
    }
    return prev;
        
    }
}

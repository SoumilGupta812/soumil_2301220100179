import java.util.*;

class Solution {

    Map<String, List<String>> graph = new HashMap<>();
    Set<String> visited = new HashSet<>();

    public List<List<String>> accountsMerge(List<List<String>> accounts) {

        
        for (List<String> account : accounts) {

            for (int i = 2; i < account.size(); i++) {

                String email1 = account.get(i - 1);
                String email2 = account.get(i);

                graph.computeIfAbsent(email1, k -> new ArrayList<>()).add(email2);
                graph.computeIfAbsent(email2, k -> new ArrayList<>()).add(email1);
            }
        }

        List<List<String>> ans = new ArrayList<>();

        
        for (List<String> account : accounts) {

            String firstEmail = account.get(1);

            if (!visited.contains(firstEmail)) {

                List<String> emails = new ArrayList<>();

                dfs(firstEmail, emails);

                Collections.sort(emails);

                List<String> merged = new ArrayList<>();
                merged.add(account.get(0)); 
                merged.addAll(emails);

                ans.add(merged);
            }
        }

        return ans;
    }

    private void dfs(String email, List<String> emails) {

        visited.add(email);
        emails.add(email);

        for (String neighbor : graph.getOrDefault(email, new ArrayList<>())) {

            if (!visited.contains(neighbor)) {
                dfs(neighbor, emails);
            }
        }
    }
}
